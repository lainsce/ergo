cask fizzbuzz
bring stdr
-- Yis Example: FizzBuzz

!: mod(divisor = num) (( bool ))
    this % divisor == 0
;

: fizzbuzz(n = num) (( -- ))
    for (let ?i = 1; i <= n; i += 1)
        let ?flag = false
        if i !mod 3
            write("Fizz\n")
            flag = true
        elif i !mod 5
            write("Buzz\n")
            flag = true
        elif !flag
            writef("$$i$$\n")
;

-> ()
    write("== FizzBuzz Example ==\n")
    fizzbuzz(20)
    write("== Done ==\n")
;
